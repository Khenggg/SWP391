# Copy this file to .env and replace every placeholder with a rotated local credential.
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://localhost:5000
ConnectionStrings__DefaultConnection=Host=<pooler-host>;Port=5432;Database=postgres;Username=<pooler-username>;Password=<database-password>;SSL Mode=Require
JWT_SECRET=__SET_A_ROTATED_SECRET_AT_LEAST_32_BYTES__
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Supabase Storage (backend only; never expose the service role key in the frontend).
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=__SET_BY_ENV_OR_USER_SECRETS__
SUPABASE_STORAGE_BUCKET=parking-images
SUPABASE_SIGNED_URL_EXPIRES_SECONDS=900
SUPABASE_MAX_UPLOAD_BYTES=5242880

# PayOS is required only for payment flows.
PAYOS_CLIENT_ID=__SET_BY_ENV_OR_USER_SECRETS__
PAYOS_API_KEY=__SET_BY_ENV_OR_USER_SECRETS__
PAYOS_CHECKSUM_KEY=__SET_BY_ENV_OR_USER_SECRETS__
PAYOS_WEBHOOK_URL=__SET_BY_ENV_OR_USER_SECRETS__
PAYOS_RETURN_URL=http://localhost:5173
PAYOS_CANCEL_URL=http://localhost:5173
