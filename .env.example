# Root environment template
# Copy to .env for local scripts only. Do not commit real credentials.

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=parking_building
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_SSL_MODE=disable

CORE_API_URL=http://localhost:5000
SUPPORT_API_URL=http://localhost:8080
PUBLIC_API_URL=http://localhost:8080
FRONTEND_URL=http://localhost:5173

JWT_ISSUER=parking-building-auth
JWT_AUDIENCE=parking-building-api
JWT_SECRET=change-this-to-a-long-dev-secret
