#!/bin/sh

commit_msg_file="$1"
first_line="$(sed -n '1p' "$commit_msg_file")"
max_length=100

case "$first_line" in
  Merge\ *|Revert\ *)
    exit 0
    ;;
esac

if [ "${#first_line}" -gt "$max_length" ]; then
  echo "ERROR: Commit message first line is longer than ${max_length} characters." >&2
  exit 1
fi

if printf '%s\n' "$first_line" | grep -Eq '^(feat|fix|docs|chore|refactor|test|build|ci|style|perf|revert)(\([A-Za-z0-9._-]+\))?(!)?: .+'; then
  exit 0
fi

echo "ERROR: Commit message must follow Conventional Commits." >&2
echo "Examples:" >&2
echo "  feat(auth): add login endpoint" >&2
echo "  fix(database): correct parking slot seed data" >&2
echo "  docs: update API contract" >&2
echo "Allowed types: feat, fix, docs, chore, refactor, test, build, ci, style, perf, revert" >&2
exit 1
